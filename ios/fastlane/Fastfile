# Fastlane — build IPA Flutter e upload su App Store Connect
#
# Lane:
#   beta    → TestFlight (build + upload)
#   release → App Store Connect (build + upload, senza invio in review)
#   build   → solo build IPA (nessun upload)
#
# Variabili utili:
#   APP_STORE_CONNECT_API_KEY_ID
#   APP_STORE_CONNECT_ISSUER_ID
#   APP_STORE_CONNECT_API_KEY_CONTENT   (contenuto .p8, base64 in CI)
#   APP_STORE_CONNECT_API_KEY_PATH      (percorso .p8 in locale)
#   EXPORT_OPTIONS_PLIST                (default: ios/ExportOptions.plist)
#   FLUTTER_BUILD_ARGS                  (es. --dart-define=...)

default_platform(:ios)

def project_root
  File.expand_path("../..", __dir__)
end

def export_options_plist
  ENV.fetch("EXPORT_OPTIONS_PLIST", File.join(project_root, "ios/ExportOptions.plist"))
end

def flutter_ipa_path
  ipa = Dir[File.join(project_root, "build/ios/ipa/*.ipa")].max_by { |f| File.mtime(f) }
  UI.user_error!("IPA non trovato in build/ios/ipa/") unless ipa && File.exist?(ipa)
  ipa
end

def fetch_app_store_connect_api_key
  if ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    return app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"],
      duration: 1200,
      in_house: false
    )
  end

  if ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]
    return app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: ENV.fetch("APP_STORE_CONNECT_API_KEY_BASE64", "false") == "true",
      duration: 1200,
      in_house: false
    )
  end

  nil
end

def build_flutter_ipa
  extra_args = ENV.fetch("FLUTTER_BUILD_ARGS", "").split.reject(&:empty?)

  Dir.chdir(project_root) do
    sh("flutter", "pub", "get")
    sh(
      "flutter", "build", "ipa", "--release",
      "--export-options-plist=#{export_options_plist}",
      *extra_args
    )
  end

  flutter_ipa_path
end

platform :ios do
  desc "Solo build IPA release (nessun upload)"
  lane :build do
    setup_ci if ENV["CI"]
    ipa = build_flutter_ipa
    UI.success("IPA generato: #{ipa}")
    ipa
  end

  desc "Build + upload su TestFlight"
  lane :beta do
    setup_ci if ENV["CI"]
    ipa = build_flutter_ipa
    api_key = fetch_app_store_connect_api_key

    upload_params = {
      ipa: ipa,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    }
    upload_params[:api_key] = api_key if api_key

    upload_to_testflight(**upload_params)
    UI.success("Build caricata su TestFlight")
  end

  desc "Build + upload su App Store Connect (senza invio in review)"
  lane :release do
    setup_ci if ENV["CI"]
    ipa = build_flutter_ipa
    api_key = fetch_app_store_connect_api_key

    upload_params = {
      ipa: ipa,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      precheck_include_in_app_purchases: false
    }
    upload_params[:api_key] = api_key if api_key

    upload_to_app_store(**upload_params)
    UI.success("Build caricata su App Store Connect")
  end
end
