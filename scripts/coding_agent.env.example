# Copia in coding_agent.env e personalizza (il file .env non va in git).

# Provider predefinito: ollama | openai | anthropic | custom
CODING_AGENT_PROVIDER=ollama

# Modello LLM (es. qwen2.5-coder:7b, gpt-4o-mini, claude-sonnet-4-20250514)
CODING_AGENT_MODEL=qwen2.5-coder:7b

# --- Ollama (locale) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- OpenAI (remoto) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic (remoto) ---
ANTHROPIC_API_KEY=

# --- API OpenAI-compatible (LM Studio, vLLM, OpenRouter, ecc.) ---
CUSTOM_BASE_URL=http://localhost:1234/v1
CUSTOM_API_KEY=not-needed
CUSTOM_MODEL=local-model

# Contesto inviato al modello
CODING_AGENT_MAX_CONTEXT_FILES=25
CODING_AGENT_MAX_FILE_BYTES=60000
